include(_common)
include(_linux_x86_64_release)

{% set cc = "/usr/bin/clang-20" %}
{% set cxx = "/usr/bin/clang++-20" %}

[settings]
compiler=clang
compiler.version=20
compiler.cppstd=gnu23
compiler.libcxx=libstdc++11

[conf]
tools.build:compiler_executables={"c": "{{ cc }}", "cpp": "{{ cxx }}"}

[buildenv]
CC={{ cc }}
CXX={{ cxx }}
